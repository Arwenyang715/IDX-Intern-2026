# ======================
# 7. Fetch mortgage rate data from FRED
url = "https://fred.stlouisfed.org/graph/fredgraph.csv?id=MORTGAGE30US"
mortgage = pd.read_csv(url, parse_dates=['observation_date'])
mortgage.columns = ['date', 'rate_30yr_fixed']

# ======================
# 8. Convert weekly data to monthly averages
mortgage['year_month'] = mortgage['date'].dt.to_period('M')

mortgage_monthly = (
    mortgage.groupby('year_month')['rate_30yr_fixed']
    .mean()
    .reset_index()
)

# ======================
# 9. Create matching keys for merge
sold['CloseDate'] = pd.to_datetime(sold['CloseDate'])
sold['year_month'] = sold['CloseDate'].dt.to_period('M')

listed['ListingContractDate'] = pd.to_datetime(listed['ListingContractDate'])
listed['year_month'] = listed['ListingContractDate'].dt.to_period('M')

# ======================
# 10. Merge mortgage data
sold = sold.merge(mortgage_monthly, on='year_month', how='left')
listed = listed.merge(mortgage_monthly, on='year_month', how='left')

# ======================
# 11. Validate merge results
print("\nMissing mortgage rates in SOLD:", sold['rate_30yr_fixed'].isnull().sum())
print("Missing mortgage rates in LISTED:", listed['rate_30yr_fixed'].isnull().sum())

# ======================
# 12. Save final datasets
sold.to_csv(f'{output_dir}/Sold_Processed.csv', index=False)
listed.to_csv(f'{output_dir}/Listed_Processed.csv', index=False)

print("\n✅ Week 2–3 processing completed successfully")
