# 6. Numeric distribution summary
def numeric_summary(df, column):
    print(f"\n=== Summary Statistics for {column} ===")
    print(df[column].describe(percentiles=[0.01, 0.05, 0.25, 0.5, 0.75, 0.95, 0.99]))

# Required fields
